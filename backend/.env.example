# Database
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/ai_task_manager

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
APP_NAME=AI Task Manager
APP_VERSION=1.0.0
DEBUG=True

# Vector DB
VECTOR_DB_PATH=./vector_store
EMBEDDING_MODEL=all-MiniLM-L6-v2

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
